# Copy this file to .env.local for local development.
# Never commit .env.local to git — it is already in .gitignore.
#
# ─── Backend API URL ──────────────────────────────────────────────────────────
# Points the Next.js frontend at the FastAPI backend.
#
#   Local dev  →  http://localhost:8000  (default if variable is unset)
#   Production →  set NEXT_PUBLIC_API_URL in Vercel:
#                 Project Settings → Environment Variables
#                 Value: https://your-backend.up.railway.app
#
# The NEXT_PUBLIC_ prefix is required so Next.js includes this value in
# the browser bundle (client-side components read it at runtime).
# NEVER put secrets (API keys, Supabase service key) in NEXT_PUBLIC_ vars.
#
NEXT_PUBLIC_API_URL=http://localhost:8000
